{
  "name": "05 — EQR Conflict Notification",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "conflict-detected", "responseMode": "responseNode" },
      "id": "conflict-webhook",
      "name": "Conflict Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $env['SUPABASE_URL'] }}/rest/v1/events",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "id", "value": "=in.({{ $json.body.record.event_id_a }},{{ $json.body.record.event_id_b }})" },
            { "name": "select", "value": "id,title,start_at,end_at,member_id" }
          ]
        }
      },
      "id": "load-conflicting-events",
      "name": "Load Conflicting Events",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const events = $json;\nconst eventA = events[0];\nconst eventB = events[1];\nreturn [{ json: {\n  title: '⚠️ Conflito de agenda detectado',\n  body: `\"${eventA.title}\" conflita com \"${eventB.title}\"`,\n  memberId: $('Conflict Webhook').first().json.body.record.member_id,\n  eventId: eventA.id\n}}];"
      },
      "id": "build-notification",
      "name": "Build Notification",
      "type": "n8n-nodes-base.code",
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "={{ $env['SUPABASE_URL'] }}/rest/v1/notifications",
        "requestMethod": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "member_id", "value": "={{ $json.memberId }}" },
            { "name": "type", "value": "conflict_detected" },
            { "name": "title", "value": "={{ $json.title }}" },
            { "name": "body", "value": "={{ $json.body }}" },
            { "name": "event_id", "value": "={{ $json.eventId }}" }
          ]
        }
      },
      "id": "insert-notification",
      "name": "Insert Notification (Realtime trigger)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 300]
    }
  ],
  "connections": {
    "Conflict Webhook": { "main": [[{ "node": "Load Conflicting Events", "type": "main", "index": 0 }]] },
    "Load Conflicting Events": { "main": [[{ "node": "Build Notification", "type": "main", "index": 0 }]] },
    "Build Notification": { "main": [[{ "node": "Insert Notification (Realtime trigger)", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["eqr", "notifications"]
}
