{
  "name": "02 — EQR Event Update Sync (Outbound)",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "event-update", "responseMode": "responseNode" },
      "id": "webhook-receiver",
      "name": "Webhook Receiver",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.body.event.google_event_id }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ]
        }
      },
      "id": "has-google-id",
      "name": "Has Google Event ID?",
      "type": "n8n-nodes-base.if",
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "// Se não tem google_event_id, delega para o workflow de criação\nconst event = $input.first().json.body.event;\n$execution.customData.set('shouldCreate', true);\nreturn [{ json: event }];"
      },
      "id": "route-to-create",
      "name": "Route: No Google ID → Create",
      "type": "n8n-nodes-base.code",
      "position": [680, 420]
    },
    {
      "parameters": {
        "url": "=https://www.googleapis.com/calendar/v3/calendars/{{ $('Webhook Receiver').first().json.body.google_account.calendar_id }}/events/{{ $('Webhook Receiver').first().json.body.event.google_event_id }}",
        "requestMethod": "PATCH",
        "authentication": "oAuth2Api",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "=",
              "value": "={{ { summary: $json.body.event.title, description: $json.body.event.description, location: $json.body.event.location, start: { dateTime: $json.body.event.start_at, timeZone: 'America/Sao_Paulo' }, end: { dateTime: $json.body.event.end_at, timeZone: 'America/Sao_Paulo' } } }}"
            }
          ]
        }
      },
      "id": "patch-google-event",
      "name": "Google Calendar: Patch Event",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 200]
    },
    {
      "parameters": {
        "url": "={{ $env['NEXT_PUBLIC_APP_URL'] }}/api/webhooks/n8n",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "=",
              "value": "={{ { operation: 'sync_status', eventId: $('Webhook Receiver').first().json.body.event.id, syncStatus: 'synced', event: { member_id: $('Webhook Receiver').first().json.body.event.member_id } } }}"
            }
          ]
        }
      },
      "id": "update-synced",
      "name": "Update Sync: Synced",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 200]
    }
  ],
  "connections": {
    "Webhook Receiver": { "main": [[{ "node": "Has Google Event ID?", "type": "main", "index": 0 }]] },
    "Has Google Event ID?": {
      "main": [
        [{ "node": "Route: No Google ID → Create", "type": "main", "index": 0 }],
        [{ "node": "Google Calendar: Patch Event", "type": "main", "index": 0 }]
      ]
    },
    "Google Calendar: Patch Event": { "main": [[{ "node": "Update Sync: Synced", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["eqr", "calendar-sync", "outbound"]
}
