{
  "name": "04 — EQR Google Inbound Sync (Bidirectional)",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "google-push", "responseMode": "responseNode" },
      "id": "google-webhook-receiver",
      "name": "Google Push Notification Receiver",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// Valida o header X-Goog-Channel-Token do Google\nconst token = $input.first().json.headers['x-goog-channel-token'];\nconst expectedToken = $env['GOOGLE_PUSH_NOTIFICATION_TOKEN'];\nif (token !== expectedToken) throw new Error('Invalid Google push token');\nreturn $input.all();"
      },
      "id": "validate-google-token",
      "name": "Validate Google Token",
      "type": "n8n-nodes-base.code",
      "position": [460, 300]
    },
    {
      "parameters": {
        "url": "={{ $env['SUPABASE_URL'] }}/rest/v1/google_calendar_accounts",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "webhook_channel_id", "value": "=eq.{{ $json.headers['x-goog-channel-id'] }}" },
            { "name": "select", "value": "id,member_id,calendar_id,access_token,refresh_token,token_expires_at,metadata" }
          ]
        }
      },
      "id": "find-member-by-channel",
      "name": "Find Member by Channel ID",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "=https://www.googleapis.com/calendar/v3/calendars/{{ $json[0].calendar_id }}/events",
        "authentication": "oAuth2Api",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "syncToken", "value": "={{ $json[0].metadata?.syncToken ?? '' }}" },
            { "name": "singleEvents", "value": "true" }
          ]
        }
      },
      "id": "get-changed-events",
      "name": "Get Changed Events (incremental sync)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "// Classifica eventos: new / modified / cancelled\nconst items = $json.items ?? [];\nconst memberId = $('Find Member by Channel ID').first().json[0].member_id;\nreturn items.map(e => ({\n  json: {\n    googleEventId: e.id,\n    memberId,\n    eventType: e.status === 'cancelled' ? 'cancelled' : (e.created === e.updated ? 'new' : 'modified'),\n    title: e.summary ?? '(sem título)',\n    description: e.description ?? null,\n    location: e.location ?? null,\n    startAt: e.start?.dateTime ?? e.start?.date,\n    endAt: e.end?.dateTime ?? e.end?.date,\n    allDay: !e.start?.dateTime\n  }\n}));"
      },
      "id": "classify-changes",
      "name": "Classify Changes",
      "type": "n8n-nodes-base.code",
      "position": [1120, 300]
    },
    {
      "parameters": {
        "url": "={{ $env['NEXT_PUBLIC_APP_URL'] }}/api/webhooks/n8n",
        "requestMethod": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "=",
              "value": "={{ { operation: $json.eventType === 'cancelled' ? 'delete' : 'create', event: { member_id: $json.memberId, google_event_id: $json.googleEventId, title: $json.title, start_at: $json.startAt, end_at: $json.endAt } } }}"
            }
          ]
        }
      },
      "id": "upsert-in-supabase",
      "name": "Upsert in Supabase via API",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1340, 300]
    },
    {
      "parameters": {
        "url": "={{ $env['SUPABASE_URL'] }}/rest/v1/google_calendar_accounts",
        "requestMethod": "PATCH",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "id", "value": "=eq.{{ $('Find Member by Channel ID').first().json[0].id }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "metadata", "value": "={{ { syncToken: $('Get Changed Events (incremental sync)').first().json.nextSyncToken } }}" }
          ]
        }
      },
      "id": "update-sync-token",
      "name": "Update syncToken",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1560, 300]
    }
  ],
  "connections": {
    "Google Push Notification Receiver": { "main": [[{ "node": "Validate Google Token", "type": "main", "index": 0 }]] },
    "Validate Google Token": { "main": [[{ "node": "Find Member by Channel ID", "type": "main", "index": 0 }]] },
    "Find Member by Channel ID": { "main": [[{ "node": "Get Changed Events (incremental sync)", "type": "main", "index": 0 }]] },
    "Get Changed Events (incremental sync)": { "main": [[{ "node": "Classify Changes", "type": "main", "index": 0 }]] },
    "Classify Changes": { "main": [[{ "node": "Upsert in Supabase via API", "type": "main", "index": 0 }]] },
    "Upsert in Supabase via API": { "main": [[{ "node": "Update syncToken", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["eqr", "calendar-sync", "inbound"]
}
